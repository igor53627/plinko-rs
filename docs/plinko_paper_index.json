  "key_takeaways": {
    "problem": "Single-server PIR with client preprocessing - prior schemes had suboptimal query time O˜(r + n/r) for large client storage r",
    "solution": "Invertible PRFs enable O˜(1) hint searching, achieving optimal O˜(n/r) query time for all r",
    "innovation": "New iPRF primitive built from one-way functions only, secure for arbitrary domain/range sizes",
    "practical_impact": [
      "First optimal trade-off curve for all client storage sizes",
      "First worst-case O˜(1) update time for PIR with preprocessing",
      "Simple modification to existing schemes (RMS, Piano)"
    ]
  },
